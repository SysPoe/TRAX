{
  "type": "module",
  "name": "translink-rail-api",
  "version": "0.1.11",
  "description": "High-level API for TransLink Rail services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "devDependencies": {
    "@types/node": "^24.0.14",
    "assemblyscript": "^0.28.9",
    "prettier": "^3.6.2",
    "tsx": "^3.12.7",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/cli-progress": "^3.11.6",
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "dotenv": "^17.2.3",
    "node-html-parser": "^7.0.2",
    "qdf-gtfs": "github:SysPoe/QDF-GTFS",
    "strip-ansi": "^7.1.2"
  },
  "scripts": {
    "build": "npm run asbuild && tsc",
    "prepare": "npm run build",
    "format": "prettier . --write --config .prettierrc",
    "asbuild:debug": "asc assembly/index.ts --target debug --enable threads --initialMemory 100 --maximumMemory 1000 --sharedMemory",
    "asbuild:release": "asc assembly/index.ts --target release --enable threads --initialMemory 100 --maximumMemory 1000 --sharedMemory",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "test": "node tests",
    "start": "npx serve ."
  },
  "files": [
    "dist",
    "build"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
